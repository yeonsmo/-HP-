# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
#   복사: (윈도우) copy .env.example .env   /  (맥·리눅스) cp .env.example .env

# SQLite 데이터베이스 파일의 전체 경로.
# NAS의 지정 폴더를 가리키게 하세요. 폴더가 없으면 자동 생성합니다.
#
# 아래 DB_PATH 를 본인 NAS 경로로 바꾸세요. 다른 예시)
#   윈도우(UNC 경로):        DB_PATH=\\NAS\share\bep\bep.db
#   리눅스/맥(NAS 마운트):   DB_PATH=/mnt/nas/bep/bep.db
DB_PATH=Z:\bep\bep.db

# 웹 접속 포트 (기본 3000). 브라우저에서 http://localhost:포트 로 접속합니다.
PORT=3000
